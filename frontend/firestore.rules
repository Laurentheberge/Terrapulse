rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Citizens can read/write only their own reports
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.citizen_id;
      allow update, delete: if request.auth != null
                            && (
                              request.auth.uid == resource.data.citizen_id
                              || request.auth.token.role == 'authority'
                            );
    }

    // Disposal sites: anyone can read, only authority can write
    match /disposal_sites/{siteId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                                     && request.auth.token.role == 'authority';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
